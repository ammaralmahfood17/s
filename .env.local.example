# ============================================================
# Dokan — Environment Variables (Local Development)
# ============================================================
# Copy this file to .env.local and fill in your values

# Supabase — get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App
NEXT_PUBLIC_APP_URL=https://dokanstore.xyz
NEXT_PUBLIC_APP_NAME=Dokan
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# Push Notifications (Web Push / VAPID)
# Generate keys: npx web-push generate-vapid-keys
# Then set both in Vercel: VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@dokan.bh
